# API Configuration
# Base URL for the explorer API (defaults to /api/v1 when served by the Docker container)
VITE_API_BASE_URL=/api/v1
VITE_API_TIMEOUT=15000

# Backend URL for dev proxy and WebSocket derivation (defaults to http://localhost:4000)
# VITE_BACKEND_URL=http://localhost:4000

# Environment
VITE_NODE_ENV=development
