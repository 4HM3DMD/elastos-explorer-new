# Copy to /opt/ela-explorer/.env — variable names must match what the explorer binary reads.
# NEVER commit .env to git.

DB_PASSWORD=your_indexer_password
DB_API_PASSWORD=your_api_readonly_password

# ELA node JSON-RPC (required names — do not use RPC_USER here; Compose does not map it)
ELA_NODE_RPC_USER=your_ela_node_rpc_user
ELA_NODE_RPC_PASS=your_ela_node_rpc_pass

FRONTEND_HTML=/opt/ela-explorer/dist/index.html

# Optional: comma-separated public ELA RPCs for cross-checking chain height
# REFERENCE_RPC_URLS=https://rpc.elastos.info/ela,https://api.elastos.io/ela
